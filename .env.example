# Docker Hub username (set as GitHub Variable: DOCKERHUB_USERNAME)
DOCKERHUB_USERNAME=glorywachira

# Application name (must be lowercase - matches repo name lowercased)
APP_NAME=devops-production-style-service-environment

# Image tag to deploy (use sha-<short-commit-hash>, never latest)
# Example: sha-a1b2c3d
IMAGE_TAG=sha-replace-with-actual-hash
