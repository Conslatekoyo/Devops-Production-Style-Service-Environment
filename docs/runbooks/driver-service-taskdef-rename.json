{
    "family": "devops-g8-driver-service-task",
    "taskRoleArn": "arn:aws:iam::827478161993:role/devops-g8-ecs-task-role",
    "executionRoleArn": "arn:aws:iam::827478161993:role/devops-g8-ecs-execution-role",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "256",
    "memory": "512",
    "containerDefinitions": [
        {
            "name": "driver-service",
            "image": "827478161993.dkr.ecr.eu-west-3.amazonaws.com/devops-g8-driver-service:a4c16ec",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 3002,
                    "hostPort": 3002,
                    "protocol": "tcp",
                    "name": "driver-service",
                    "appProtocol": "http"
                }
            ],
            "environment": [
                { "name": "PORT", "value": "3002" },
                { "name": "BIND_HOST", "value": "0.0.0.0" },
                { "name": "SERVICE_C_URL", "value": "http://tracking-service.group8.internal:3003" }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/devops-g8-driver-service",
                    "awslogs-region": "eu-west-3",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "healthCheck": {
                "command": ["CMD-SHELL", "node -e \"fetch('http://localhost:3002/health').then(r=>r.status<500?process.exit(0):process.exit(1)).catch(()=>process.exit(1))\""],
                "interval": 10,
                "timeout": 3,
                "retries": 5,
                "startPeriod": 10
            }
        }
    ]
}
